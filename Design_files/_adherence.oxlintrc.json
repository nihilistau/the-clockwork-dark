{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/core/**",
              "components/feedback/**",
              "components/scene/**",
              "deck/**",
              "ui_kits/clockwork-scene/**",
              "ui_kits/clockwork-world/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:EB Garamond|Source Sans 3|IBM Plex Mono|Nunito))/i]",
        "message": "Font not provided by the design system. Available: EB Garamond, Source Sans 3, IBM Plex Mono, Nunito."
      },
      {
        "selector": "JSXOpeningElement[name.name='AssistantBubble'] > JSXAttribute > JSXIdentifier[name!=/^(?:form|whisper|hidden|children|key|ref|className|style|children)$/]",
        "message": "<AssistantBubble> doesn't accept that prop. Declared props: form, whisper, hidden, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:tone|children|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: tone, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:neutral|candle|brass|moss|danger|corruption)$/]",
        "message": "<Badge> tone must be one of 'neutral' | 'candle' | 'brass' | 'moss' | 'danger' | 'corruption'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|size|disabled|iconLeft|iconRight|children|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: variant, size, disabled, iconLeft, iconRight, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|secondary|ghost|danger)$/]",
        "message": "<Button> variant must be one of 'primary' | 'secondary' | 'ghost' | 'danger'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Button> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='ChoiceChip'] > JSXAttribute > JSXIdentifier[name!=/^(?:index|disabled|onClick|children|key|ref|className|style|children)$/]",
        "message": "<ChoiceChip> doesn't accept that prop. Declared props: index, disabled, onClick, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='DiceToast'] > JSXAttribute > JSXIdentifier[name!=/^(?:roll|modifier|dc|outcome|key|ref|className|style|children)$/]",
        "message": "<DiceToast> doesn't accept that prop. Declared props: roll, modifier, dc, outcome."
      },
      {
        "selector": "JSXOpeningElement[name.name='ScenePanel'] > JSXAttribute > JSXIdentifier[name!=/^(?:title|surface|edge|children|key|ref|className|style|children)$/]",
        "message": "<ScenePanel> doesn't accept that prop. Declared props: title, surface, edge, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='ScenePanel'] > JSXAttribute[name.name='surface'] > Literal[value!=/^(?:ledger|panel|narrative|card)$/]",
        "message": "<ScenePanel> surface must be one of 'ledger' | 'panel' | 'narrative' | 'card'."
      },
      {
        "selector": "JSXOpeningElement[name.name='ScenePanel'] > JSXAttribute[name.name='edge'] > Literal[value!=/^(?:none|left|right)$/]",
        "message": "<ScenePanel> edge must be one of 'none' | 'left' | 'right'."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatLine'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|value|accent|key|ref|className|style|children)$/]",
        "message": "<StatLine> doesn't accept that prop. Declared props: label, value, accent."
      },
      {
        "selector": "JSXOpeningElement[name.name='WorldClock'] > JSXAttribute > JSXIdentifier[name!=/^(?:day|time|discovered|key|ref|className|style|children)$/]",
        "message": "<WorldClock> doesn't accept that prop. Declared props: day, time, discovered."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
